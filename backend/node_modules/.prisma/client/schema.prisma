datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Detector {
  id        String      @id @default(cuid())
  name      String
  type      String
  config    Json
  enabled   Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  events    BarkEvent[]
}

model BarkEvent {
  id            String   @id @default(cuid())
  detectorId    String
  detector      Detector @relation(fields: [detectorId], references: [id])
  startTime     DateTime
  endTime       DateTime
  confidence    Float
  audioFilePath String?
  videoFilePath String?
  reviewed      Boolean  @default(false)
  label         String?
  thresholdUsed Float
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([startTime])
  @@index([reviewed])
  @@index([detectorId])
}

model Recording {
  id        String    @id @default(cuid())
  filePath  String
  startTime DateTime
  endTime   DateTime?
  sizeBytes BigInt    @default(0)
  createdAt DateTime  @default(now())

  @@index([startTime])
}

model AppConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
